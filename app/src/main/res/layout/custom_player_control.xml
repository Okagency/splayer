<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 상단 컨트롤 바 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/player_control_gradient_top"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/exo_back"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/videoTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/subtitleCodecInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:background="#80000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/engineToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="EXO"
            android:textColor="#FF64B5F6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#80000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />

        <TextView
            android:id="@+id/decoderIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="HW+"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#80000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />

        <ImageButton
            android:id="@+id/btnContinuousSegment"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_playlist_play"
            android:contentDescription="구간연속재생"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnCast"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_cast"
            android:contentDescription="DLNA 캐스트" />

        <ImageButton
            android:id="@+id/btnSoundToggle"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_volume_on"
            android:contentDescription="소리 ON/OFF" />

        <ImageButton
            android:id="@+id/btnSubtitle"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_subtitles"
            android:contentDescription="자막 선택" />

        <ImageButton
            android:id="@+id/btnRotate"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_rotate"
            android:contentDescription="회전" />

        <ImageButton
            android:id="@+id/exo_settings"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="@string/settings" />

        <ImageButton
            android:id="@+id/btnOverflow"
            style="@style/ExoMediaButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="더보기"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 중앙 재생/일시정지 버튼 -->
    <ImageButton
        android:id="@+id/exo_play_pause"
        style="@style/ExoMediaButton.Center"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/play_pause" />

    <!-- 하단 컨트롤 바 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/player_control_gradient_bottom"
        android:padding="16dp"
        android:layout_marginBottom="74dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 시간 표시 및 시크바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:minWidth="60dp"
                android:gravity="center" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@+id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:played_color="@color/primary"
                app:scrubber_color="@color/primary"
                app:buffered_color="@color/buffered"
                app:unplayed_color="@color/unplayed" />

            <TextView
                android:id="@+id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:minWidth="60dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- 구간 제어 버튼 (시크바 아래) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnSegmentStart"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="F"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                style="?android:attr/borderlessButtonStyle"
                android:padding="0dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="구간 시작" />

            <Button
                android:id="@+id/btnSegmentEnd"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="T"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                style="?android:attr/borderlessButtonStyle"
                android:padding="0dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                android:contentDescription="구간 종료" />

            <Button
                android:id="@+id/btnSegmentPlaybackToggle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="구간"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                style="?android:attr/borderlessButtonStyle"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="구간 재생 ON/OFF" />

            <ImageButton
                android:id="@+id/btnSegmentList"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="구간 리스트" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
