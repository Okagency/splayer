<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/splitToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="4dp"
        app:title="영상 분할"
        app:titleTextColor="@color/on_surface"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- 영상 미리보기 -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <androidx.media3.ui.PlayerView
            android:id="@+id/splitPlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:resize_mode="fit" />

        <!-- 영상 미선택 안내 -->
        <TextView
            android:id="@+id/txtSelectGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="영상을 선택하세요"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- 시크바 + 시간 정보 -->
    <LinearLayout
        android:id="@+id/seekSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/surface"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/splitSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/txtCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 키프레임 번호 표시 + 입력 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KF #"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <EditText
                android:id="@+id/editKeyframeNumber"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:inputType="number"
                android:textSize="12sp"
                android:padding="2dp"
                android:background="@android:drawable/editbox_background"
                android:imeOptions="actionGo" />

            <TextView
                android:id="@+id/txtTotalKeyframes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/ 0"
                android:textSize="12sp"
                android:layout_marginStart="2dp"
                android:textColor="?android:attr/textColorSecondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txtTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
    </LinearLayout>

    <!-- From/To + Add 버튼 -->
    <LinearLayout
        android:id="@+id/controlSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/surface"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnFrom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="From"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnTo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="To"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnAddSegment"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Add"
                android:textSize="13sp"
                android:enabled="false"
                style="@style/Widget.Material3.Button.TonalButton" />
        </LinearLayout>

        <!-- From/To 정보 표시 -->
        <TextView
            android:id="@+id/txtFromToInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="4dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 구간 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/splitSegmentList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnSelectVideo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="영상 선택"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btnOutputFolder"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="저장: Movies"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btnStartSplit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="분할 시작"
            android:textSize="14sp"
            android:enabled="false"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>

</LinearLayout>
