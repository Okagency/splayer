<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/mergeOrderNumber"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="1"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="#FF4081" />

    <ImageView
        android:id="@+id/mergeThumbnail"
        android:layout_width="80dp"
        android:layout_height="45dp"
        android:layout_marginStart="8dp"
        android:scaleType="centerCrop"
        android:background="#333333" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/mergeFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/mergeDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnMergeUp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:src="@android:drawable/arrow_up_float"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="위로 이동" />

    <ImageButton
        android:id="@+id/btnMergeDown"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:src="@android:drawable/arrow_down_float"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="아래로 이동" />

    <ImageButton
        android:id="@+id/btnMergeRemove"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_delete"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="제거" />

</LinearLayout>
